{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Australia/Melbourne",
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchSourceUrls": [
        "https://github.com/maxcountryman/tower-sessions"
      ],
      "groupName": "tower-sessions monorepo"
    },
    {
      "description": "Run Nix lock file maintenance weekly",
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "matchFileNames": [
        "**/flake.nix"
      ],
      "schedule": [
        "before 4am on monday"
      ],
      "groupName": "nix lock file maintenance",
      "commitMessageTopic": "nix lock file"
    }
  ],
  /*
   * Update all lock files
   */
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on the first day of the month"
    ]
  },
  /*
   * Avoid churn
   */
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  /*
   * Make failures obvious instead of retrying forever
   */
  "rebaseWhen": "conflicted"
}